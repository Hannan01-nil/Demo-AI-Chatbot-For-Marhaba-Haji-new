# Example environment variables for Marhaba Haji Chatbot
# Copy to `.env` and fill values before running in production

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SENDGRID_API_KEY=
EMAIL_FROM=

MONGO_URI=mongodb://user:pass@host:27017/dbname
GOOGLE_API_KEY=
APP_URL=http://localhost:8000

# Set to "true" to enable the background scheduler when running in production containers
ENABLE_SCHEDULER=true

# Vercel sets this to "1" automatically when running as a serverless function
VERCEL=0
